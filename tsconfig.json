{
    "compilerOptions": {
      "target": "es2024",
      "module": "node20",
      "outDir": "./lib",
      "rootDir": "./src",
      "strict": true,
      "noImplicitAny": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "exclude": [
      "node_modules",
      "**/*.test.ts",
      "vite.config.ts"
    ]
  }